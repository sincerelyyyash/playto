# Backend origin for the Vite dev proxy (browser calls /api/... on the dev server).
VITE_API_PROXY_TARGET=http://localhost:8000

# Production: full URL of the Django API (no trailing slash). If unset, requests stay
# same-origin `/api/v1/...` (use when nginx or your host proxies /api to the backend).
# VITE_API_BASE_URL=https://api.playto.yashthakur.dev
