DEBUG=True
SECRET_KEY=dev-insecure-replace-me
ALLOWED_HOSTS=localhost,127.0.0.1,web

DATABASE_URL=postgres://playto:playto@postgres:5432/playto
POSTGRES_DB=playto
POSTGRES_USER=playto
POSTGRES_PASSWORD=playto

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Settlement simulation. Must sum to 1.0.
PAYOUT_SUCCESS_RATE=0.7
PAYOUT_FAILURE_RATE=0.2
PAYOUT_HANG_RATE=0.1

# Stuck payout watchdog
PAYOUT_STUCK_AFTER_SECONDS=30
PAYOUT_MAX_ATTEMPTS=3
PAYOUT_RETRY_BASE_DELAY_SECONDS=5

# Idempotency
IDEMPOTENCY_TTL_HOURS=24
# Retry POST when idempotency row has no cached response yet (orphan edge case).
IDEMPOTENCY_IN_FLIGHT_WAIT_SECONDS=30

# Celery / Redis: for rediss:// (e.g. Upstash), ssl_cert_reqs is appended automatically
# in settings if missing — required by Celery 5.4+ Redis backend.
